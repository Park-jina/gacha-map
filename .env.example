# Supabase (Next.js 앱)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 카카오맵 JavaScript SDK 앱 키 (https://developers.kakao.com)
NEXT_PUBLIC_KAKAO_MAP_APP_KEY=

# 크롤러 전용 (서버에서만 사용, 절대 커밋 금지)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# 카카오 로컬 REST API 키 (카카오맵 JS 키와 별개, 같은 앱의 REST API 키 사용)
KAKAO_REST_API_KEY=
